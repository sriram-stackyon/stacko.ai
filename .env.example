# LLM via Amzur LiteLLM proxy
LITELLM_PROXY_URL=
LITELLM_VIRTUAL_KEY=
LITELLM_MODEL=
IMAGE_GEN_MODEL=gemini/imagen-4.0-fast-generate-001
LITELLM_TEMPERATURE=0.7
LITELLM_MAX_TOKENS=2048

# Supabase
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
DATABASE_URL=

# App
DEBUG=false
HOST=0.0.0.0
PORT=8000
API_BASE_URL=http://localhost:8000
FRONTEND_BASE_URL=http://localhost:5173
GOOGLE_FRONTEND_CALLBACK_PATH=/auth/google/callback
# Optional. Keep empty to allow any email domain.
EMPLOYEE_EMAIL_DOMAIN=
AUTH_SECRET_KEY=
AUTH_TOKEN_EXPIRE_MINUTES=60
CORS_ORIGINS=["http://localhost:5173","http://localhost:3000"]

# Google OAuth
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:8000/api/auth/google/callback
GOOGLE_SERVICE_ACCOUNT_JSON=

# Sheets query agent
SHEETS_MAX_ROWS=5000

# RAG (Retrieval-Augmented Generation)
EMBEDDING_MODEL=text-embedding-3-large
CHROMA_PERSIST_DIR=./chroma_db
RAG_CHUNK_SIZE=1500
RAG_CHUNK_OVERLAP=200
RAG_TOP_K=5
RAG_SCORE_THRESHOLD=0.3
RAG_ENABLE_SUMMARIZATION=true

# Rate Limiting
RATE_LIMIT_ENABLED=true
RATE_LIMIT_REQUESTS_PER_MINUTE=60
RATE_LIMIT_TOKENS_PER_DAY=1000000

# ── Project 12: MCP arXiv Server ─────────────────────────────────────────────
# Uses the public cyanheads/arxiv-mcp-server via Streamable HTTP (no local install).
# Built-in rate limiting: 3 s crawl delay + adaptive cooldown on HTTP 429.
# Optionally override with a self-hosted instance URL.
MCP_ARXIV_URL=https://arxiv.caseyjhand.com/mcp

# Number of connection retry attempts for MCP tool calls (default: 3)
MCP_RETRY_ATTEMPTS=3

